{
  "name": "design-diff",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Локальный инструмент для визуального сравнения референс-дизайна и целевого сайта по брейкпоинтам",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "npm run build && tsx server/index.ts",
    "install:browser": "npx playwright install chromium",
    "test:figma": "tsx --test server/figma.test.ts",
    "test:figma-import": "tsx --test server/figmaImport.test.ts",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "verify": "tsx scripts/verify.ts",
    "mcp": "tsx server/mcp.ts"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.3.0",
    "@fontsource/fira-sans": "^5.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "lucide-react": "^0.469.0",
    "multer": "^1.4.5-lts.1",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.61.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.9",
    "@types/pixelmatch": "^5.2.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
